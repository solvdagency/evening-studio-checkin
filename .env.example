# Productive.io API credentials (Phase 2 ingestion).
# Copy to a gitignored `.env` for local dev; in CI these come from GitHub Actions
# encrypted secrets (D-15). NEVER commit real values — this file is the template
# (names only). See CLAUDE.md "Item 6 — Secrets & config".

# Personal access token from Productive -> Settings -> API access (X-Auth-Token header).
PRODUCTIVE_AUTH_TOKEN=

# Organization id (X-Organization-Id header). The bare numeric prefix of the org slug
# (e.g. 34092 from 34092-solvd-agency). The exact working value is confirmed by the
# live auth probe in plan 02-01 Task 4.
PRODUCTIVE_ORG_ID=

# Google Chat delivery (Phase 3 — the nightly card POST).
# The FULL incoming-webhook URL for the target Chat space, including its key+token
# query params (Chat space -> Apps & integrations -> Webhooks -> Create -> copy URL).
# This is the auth — treat it as a secret. NEVER commit the real value; in CI it
# comes from the GCHAT_WEBHOOK_URL GitHub Actions encrypted secret.
# Example shape (placeholder — NOT a real webhook):
# https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=REPLACE_KEY&token=REPLACE_TOKEN
GCHAT_WEBHOOK_URL=

# Google Calendar service-account key (Phase 4 — calendar read + the labelling spike).
# The FULL JSON of the service account key, as a single-line string (the contents of
# secrets/evening-studio-checkin-*.json). Used by googleapis `google.auth.JWT` with
# per-designer `subject` domain-wide-delegation impersonation, scope calendar.readonly.
# This is the auth — treat it as a secret. NEVER commit the real value; in CI it comes
# from the GOOGLE_SA_KEY GitHub Actions encrypted secret. Required locally to run the
# Phase 4 labelling spike (plan 04-02). NEVER log this value.
GOOGLE_SA_KEY=
