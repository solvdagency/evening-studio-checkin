# Productive.io API credentials (Phase 2 ingestion).
# Copy to a gitignored `.env` for local dev; in CI these come from GitHub Actions
# encrypted secrets (D-15). NEVER commit real values — this file is the template
# (names only). See CLAUDE.md "Item 6 — Secrets & config".

# Personal access token from Productive -> Settings -> API access (X-Auth-Token header).
PRODUCTIVE_AUTH_TOKEN=

# Organization id (X-Organization-Id header). The bare numeric prefix of the org slug
# (e.g. 34092 from 34092-solvd-agency). The exact working value is confirmed by the
# live auth probe in plan 02-01 Task 4.
PRODUCTIVE_ORG_ID=
